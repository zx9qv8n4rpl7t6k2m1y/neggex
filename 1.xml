<?xml version="1.0" encoding="UTF-8" ?>
<Module>
<ModulePrefs title="classroom" />
<Content type="html"><![CDATA[


<!DOCTYPE html>
<html lang="en-us">
<head>
<meta charset="utf-8"/>
<meta http-equiv="Content-Type" content="text/html; charset=utf-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=no"/>
<link rel="stylesheet" href="https://cdn.jsdelivr.net/gh/gulamen/neggex@main/style.css"/>
<style>
    canvas:focus { outline: none; }
    html, body {
        padding: 0; margin: 0; overflow: hidden;
        overscroll-behavior: none;
        -webkit-touch-callout: none; -webkit-user-select: none;
        -khtml-user-select: none; -moz-user-select: none;
        -ms-user-select: none; user-select: none;
        -webkit-tap-highlight-color: rgba(0,0,0,0);
        height: 100%;
    }
</style>
</head>
<body class="dark">

<div id="unity-container" class="unity-desktop">
    <canvas id="unity-canvas" tabindex="-1"></canvas>
</div>

<div id="loading-cover" style="display:none;">
    <div id="unity-loading-bar">
        <div id="site-logo">
    <img src="https://cdn.jsdelivr.net/gh/gulamen/neggex@main/logo.png" alt="negea">
</div>
        <div id="unity-progress-bar-empty" style="display:none;">
            <div id="unity-progress-bar-full"></div>
        </div>
        <div class="spinner"></div>
    </div>
</div>

<script>
/* ============================================================
   CONFIG
   ============================================================ */
const BUILD_URL  = "https://cdn.jsdelivr.net/gh/gulamen/neggex@main/Build";
const DATA_FILE  = "1.data.br";
const WASM_FILE  = "1.wasm.br";
const DATA_PARTS = 3;
const WASM_PARTS = 9;

/* ============================================================
   GLOBALS
   ============================================================ */
const NO_DATA = 'no data';

var initYSDK      = true;
var initGame      = false;
var isVisibility  = true;
var isPausedGame  = false;
var nowFullAdOpen = false;

var cloudSaves   = NO_DATA;
/* environmentData WASM başlamadan önce hazır olmalı — _InitEnvironmentData_js bunu okur */
var environmentData = JSON.stringify({
    language:'en', domain:'com', deviceType:'desktop',
    isMobile:false, isDesktop:true, isTablet:false, isTV:false,
    appID:'0', browserLang:'en', payload:'', platform:'', browser:'Other'
});
var playerData   = NO_DATA;
var paymentsData = NO_DATA;

var player   = null;
var payments = null;

let ygGameInstance = null;

/* ysdk stub — v2.008, features.LoadingAPI + Payments */
var ysdk = {
    environment: {
        i18n:    { lang: 'en', tld: 'com' },
        app:     { id: '0' },
        browser: { lang: 'en' },
        payload: ''
    },
    deviceInfo: {
        type:      'desktop',
        isMobile:  () => false,
        isDesktop: () => true,
        isTablet:  () => false,
        isTV:      () => false,
    },
    screen: { fullscreen: { status: 'off', request: ()=>{}, exit: ()=>{} } },
    adv: {
        showFullscreenAdv:  (o) => { o?.callbacks?.onOpen?.(); setTimeout(()=>{ o?.callbacks?.onClose?.(true); }, 50); },
        showRewardedVideo:  (o) => { o?.callbacks?.onOpen?.(); setTimeout(()=>{ o?.callbacks?.onRewarded?.(); o?.callbacks?.onClose?.(); }, 50); },
        showBannerAdv:      () => Promise.resolve({ stickyAdvIsShowing: false }),
        hideBannerAdv:      () => Promise.resolve(),
        getBannerAdvStatus: () => Promise.resolve({ stickyAdvIsShowing: false }),
    },
    auth:     { openAuthDialog: () => Promise.resolve() },
    features: {
        LoadingAPI:  { ready: () => {} },
        GameplayAPI: { start: () => {}, stop: () => {} },
        GamesAPI:    { getAllGames: () => Promise.reject() },
    },
    leaderboards: {
        getDescription: () => Promise.resolve({ default: false, description: { invert_sort_order: false, score_format: { options: { decimal_offset: 0 } }, type: 'numeric' } }),
        getEntries:     () => Promise.resolve({ entries: [] }),
        setScore:       () => {},
    },
    getPlayer:   () => Promise.resolve({
        isAuthorized:    () => false,
        getName:         () => '',
        getUniqueID:     () => 'unauthorized',
        getPhoto:        () => 'no data',
        getPayingStatus: () => 'unknown',
        getData:         () => Promise.resolve({}),
        setData:         () => Promise.resolve(),
    }),
    serverTime:  () => Date.now(),
    getPayments: () => Promise.reject(new Error('payments not available')),
    on: () => {},
};

/* ============================================================
   YG2Instance
   ============================================================ */
function YG2Instance(method, arg) {
    if (!ygGameInstance) return;
    try {
        if (arg !== undefined) ygGameInstance.SendMessage('YG2Instance', method, arg);
        else                   ygGameInstance.SendMessage('YG2Instance', method);
    } catch(e) {}
}

/* ============================================================
   STUBS
   ============================================================ */
function LogStyledMessage(msg, style) {
    console.log('%c' + msg, style || 'color:#FFDF73;background:#454545');
}
function FocusGame() { if (!isPausedGame) canvas.focus(); }
function InitGame()  {
    initGame = true;
    setTimeout(() => { if (isPausedGame) YG2Instance('SetPauseGame', 'true'); }, 100);
}
function SetVisibility(visibility) {
    if (initGame && isVisibility !== visibility) {
        isVisibility = visibility;
        YG2Instance('SetFocusWindowGame', visibility ? 'true' : 'false');
    }
}

function SaveCloud()  {}
function LoadCloud()  { YG2Instance('SetLoadSaves', NO_DATA); return Promise.resolve(NO_DATA); }
function StickyAdActivity() {}

function RewardedAdvShow(id) {
    YG2Instance('OpenRewardedAdv');
    setTimeout(() => {
        YG2Instance('RewardAdv', id);
        setTimeout(() => {
            YG2Instance('CloseRewardedAdv');
            setTimeout(() => { FocusGame(); }, 100);
        }, 300);
    }, 500);
}

function InterAdvShow() {
    YG2Instance('OpenInterAdv');
    setTimeout(() => { YG2Instance('CloseInterAdv', 'true'); FocusGame(); }, 50);
}

/* Payments */
function InitPayments()     { YG2Instance('PaymentsEntries', NO_DATA); return Promise.resolve(NO_DATA); }
function BuyPayments(id)    { YG2Instance('OnPurchaseFailed', id); FocusGame(); }
function ConsumePurchase()  {}
function ConsumePurchases() {}

/* Leaderboard */
function SetLeaderboard()   {}
function GetLeaderboard(nameLB) {
    YG2Instance('LeaderboardEntries', JSON.stringify({
        technoName: nameLB, isDefault: false, isInvertSortOrder: false,
        decimalOffset: 0, type: 'numeric',
        entries: 'no data', ranks: [], photos: [], names: [], scores: [], uniqueIDs: [], extraDataArray: []
    }));
}
function EntriesLB() { return {}; }

/* Auth */
function NotAuthorized() {
    return JSON.stringify({
        playerAuth: 'rejected', playerName: 'unauthorized',
        playerId: 'unauthorized', playerPhoto: 'no data', payingStatus: 'unknown'
    });
}
function InitPlayer() {
    const j = NotAuthorized();
    YG2Instance('SetAuth', j);
    return Promise.resolve(j);
}
function OpenAuthDialog() {}

/* Environment */
function RequestingEnvironmentData() {
    const j = JSON.stringify({
        language:'en', domain:'com', deviceType:'desktop',
        isMobile:false, isDesktop:true, isTablet:false, isTV:false,
        appID:'0', browserLang:'en', payload:'', platform:'', browser:'Other'
    });
    environmentData = j;
    YG2Instance('SetEnvirData', j);
    return Promise.resolve(j);
}

/* Dil override — oyun navigator.language okuyabilir */
try {
    Object.defineProperty(navigator, 'language',  { get: () => 'en', configurable: true });
    Object.defineProperty(navigator, 'languages', { get: () => ['en','en-US'], configurable: true });
} catch(e) {}

/* ============================================================
   POINTER LOCK — sağ tık kamera için korundu
   ============================================================ */
const oRequestPointerLock = Element.prototype.requestPointerLock;
Element.prototype.requestPointerLock = async function(...args) {
    try { (args[0] ||= {}).unadjustedMovement = true; await oRequestPointerLock.apply(this, args); } catch(e) {}
};

/* ============================================================
   SETUP
   ============================================================ */
const container        = document.querySelector("#unity-container");
const canvas           = document.querySelector("#unity-canvas");
const loadingCover     = document.querySelector("#loading-cover");
const progressBarEmpty = document.querySelector("#unity-progress-bar-empty");
const progressBarFull  = document.querySelector("#unity-progress-bar-full");
const spinner          = document.querySelector('.spinner');

loadingCover.style.display = "";

if (/iPhone|iPad|iPod|Android/i.test(navigator.userAgent)) {
    container.className = "unity-mobile";
}

document.addEventListener('contextmenu', e => e.preventDefault());

/* Sağ tık: pointer lock aç/kapat (FreeLookCamera için) */
canvas.addEventListener("mousedown", function(e) {
    if (e.button === 2) {
        e.preventDefault();
        canvas.focus();
        canvas.requestPointerLock();
    }
});
canvas.addEventListener("mouseup", function(e) {
    if (e.button === 2) { document.exitPointerLock(); }
});
document.addEventListener("pointerlockchange", function() {
    if (!document.pointerLockElement && ygGameInstance) {
        try { ygGameInstance.SendMessage('FreeLookCamera', 'OnPointerLockLost'); } catch(e) {}
    }
});

document.addEventListener('visibilitychange', () => SetVisibility(!document.hidden));
window.addEventListener('blur',        () => SetVisibility(false));
window.addEventListener('focus',       () => SetVisibility(true));
window.addEventListener('pointerdown', () => { FocusGame(); SetVisibility(true); });

function InstallBlurFocusBlocker() {
    if (!('onblur' in document) || window.blurFocusHandlersInstalled) return;
    window.addEventListener('blur', function() {
        const btn = document.createElement('button');
        btn.style.cssText = 'position:fixed;top:0;left:0;width:100%;height:100%;z-index:9999;background:rgba(0,0,0,0);border:none;cursor:default;';
        document.body.appendChild(btn);
        function remove() { btn.parentNode && btn.parentNode.removeChild(btn); window.removeEventListener('focus', remove); }
        window.addEventListener('focus', remove);
    });
    window.blurFocusHandlersInstalled = true;
}

/* ============================================================
   PART LOADER
   ============================================================ */
function setProgress(pct) {
    spinner.style.display          = "none";
    progressBarEmpty.style.display = "";
    progressBarFull.style.width    = Math.min(pct, 100) + "%";
}

async function fetchParts(filename, count, startPct, endPct) {
    const step   = (endPct - startPct) / count;
    const chunks = [];
    for (let i = 0; i < count; i++) {
        const resp = await fetch(`${BUILD_URL}/${filename}.part${i}`);
        if (!resp.ok) throw new Error(`HTTP ${resp.status} - ${BUILD_URL}/${filename}.part${i}`);
        chunks.push(new Uint8Array(await resp.arrayBuffer()));
        setProgress(Math.round(startPct + step * (i + 1)));
    }
    const total  = chunks.reduce((s, c) => s + c.length, 0);
    const merged = new Uint8Array(total);
    let offset = 0;
    for (const c of chunks) { merged.set(c, offset); offset += c.length; }
    return URL.createObjectURL(new Blob([merged]));
}

/* ============================================================
   MAIN
   ============================================================ */
(async () => {
    try {
        setProgress(2);

        const [dataUrl, wasmUrl] = await Promise.all([
            fetchParts(DATA_FILE, DATA_PARTS, 2,  50),
            fetchParts(WASM_FILE, WASM_PARTS, 50, 88),
        ]);

        setProgress(92);

        const config = {
            dataUrl:            dataUrl,
            frameworkUrl:       `${BUILD_URL}/1.framework.js`,   /* patch'li düz JS */
            codeUrl:            wasmUrl,
            streamingAssetsUrl: "StreamingAssets",
            companyName:        "DefaultCompany",
            productName:        "Multyplayer",
            productVersion:     "0.1.0",
        };

        const loaderScript  = document.createElement("script");
        loaderScript.src    = `${BUILD_URL}/1.loader.js`;
        loaderScript.onload = () => {
            InstallBlurFocusBlocker();
            createUnityInstance(canvas, config, (p) => {
                setProgress(Math.round(88 + p * 10));
            }).then((inst) => {
                ygGameInstance = inst;
                loadingCover.style.background = "";
                loadingCover.style.display    = "none";

                setTimeout(() => YG2Instance('InitSDKComplete'), 300);
                setTimeout(() => {
                    YG2Instance('SetEnvirData',    JSON.stringify({ language:'en', domain:'com', deviceType:'desktop', isMobile:false, isDesktop:true, isTablet:false, isTV:false, appID:'0', browserLang:'en', payload:'', platform:'', browser:'Other' }));
                    YG2Instance('SetAuth',         NotAuthorized());
                    YG2Instance('SetLoadSaves',    NO_DATA);
                    YG2Instance('PaymentsEntries', NO_DATA);
                }, 600);

                canvas.focus();
            }).catch(e => {
                console.error(e);
                progressBarFull.textContent = "Hata: " + e;
            });
        };
        document.body.appendChild(loaderScript);

    } catch (err) {
        console.error("Yukleme hatasi:", err);
        progressBarFull.style.width = "100%";
        progressBarFull.textContent = "Yukleme hatasi: " + err.message;
    }
})();
</script>

</body>
</html>

]]></Content>
</Module>
